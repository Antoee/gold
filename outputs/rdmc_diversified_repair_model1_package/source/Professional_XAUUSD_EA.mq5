         return true;

      double cci = 0.0;
      if(!indicators.CCI(1, cci))
         return true;

      if(bias == BIAS_BUY)
         return cci <= InpCCIBuyMax;
      if(bias == BIAS_SELL)
         return cci >= InpCCISellMin;
