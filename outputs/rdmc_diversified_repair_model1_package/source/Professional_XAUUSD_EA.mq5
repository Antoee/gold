   {
      double cci = 0.0;
      if(!indicators.CCI(1, cci))
         return false;

      if(bias == BIAS_BUY)
         return cci >= InpCCIBuyMin;
      if(bias == BIAS_SELL)
         return cci <= InpCCISellMax;
